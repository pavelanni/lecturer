# Lecturer configuration
# Copy this file to lecturer.toml and adjust for your course.

[course]
name = "My Course"
content_dir = "/path/to/my-course/content"
output_dir = "/path/to/my-course/output"
voice_id = "your-elevenlabs-voice-id"
lectures = [
    "lecture-01-intro",
    "lecture-02-basics",
    "lecture-03-advanced",
]
